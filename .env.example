# Root environment file for docker-compose and shared local setup.
# Service-level `.env` files are still supported and usually simpler for local development.

# Backend
BACKEND_NODE_ENV=development
BACKEND_MONGO_URI=mongodb://localhost:27017/smart-agriwaste
BACKEND_CORS_ORIGINS=http://localhost:3000,https://smart-agriwaste.vercel.app,https://smart-agriwaste-full.onrender.com
ADMIN_BOOTSTRAP_EMAILS=admin@example.com
LOG_LEVEL=info

# Dataset API
DATASET_API_MONGO_URI=mongodb://localhost:27017/smart-agriwaste

# Frontend
FRONTEND_APP_ENV=development
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api
NEXT_PUBLIC_AGRI_API_URL=http://localhost:8080
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
NEXT_PUBLIC_IMAGEKIT_AUTH_ENDPOINT=http://localhost:5000/api/imagekit/auth

# Shared third-party services
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

NEXT_PUBLIC_ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

AZURE_TRANSLATOR_ENDPOINT=
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=
